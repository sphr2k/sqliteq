{
  "name": "@minnzen/sqliteq",
  "version": "0.2.0",
  "description": "Durable message queue backed by SQLite. Inspired by goqite.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx tsc",
    "prepare": "bun run build",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "bench": "bun run bench/run.ts",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minnzen/sqliteq.git"
  },
  "bugs": {
    "url": "https://github.com/minnzen/sqliteq/issues"
  },
  "homepage": "https://github.com/minnzen/sqliteq#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sqlite",
    "queue",
    "message-queue",
    "durable",
    "local-first",
    "better-sqlite3"
  ],
  "license": "MIT",
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "better-sqlite3": "^12.8.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
